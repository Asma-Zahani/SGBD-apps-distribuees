<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             version="2.2">

    <persistence-unit name="commandePU">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.CommandesManager.entities.Client</class>
        <class>com.CommandesManager.entities.Produit</class>
        <class>com.CommandesManager.entities.Commande</class>
        <class>com.CommandesManager.entities.LigneCommande</class>

        <properties>
            <property name="javax.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/CommandesManager"/>
            <property name="javax.persistence.jdbc.user" value="root"/>
            <property name="javax.persistence.jdbc.password" value=""/>
            <property name="javax.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
        </properties>

    </persistence-unit>
</persistence>